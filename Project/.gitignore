# OS & Environment Files
.DS_Store
Thumbs.db
.env
.env.*

# Ignore everything by default to ensure only geometry_of_ai is visible/tracked
*

# Allow directories so git can traverse into them
!*/

# Do not ignore .gitignore itself
!.gitignore

# Do not ignore geometry_of_ai and its contents
!geometry_of_ai/
!geometry_of_ai/**
!dataset_and_edge_cases.md
!decision_boundaries_k3.png



# Ignore temporary, cache, and IDE files inside geometry_of_ai
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
**/env/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/htmlcov/
**/*.log
**/*.tmp
**/*.temp
**/*.err
**/*.out
**/.ipynb_checkpoints/
.vscode/
.idea/
*.swp
*.swo
